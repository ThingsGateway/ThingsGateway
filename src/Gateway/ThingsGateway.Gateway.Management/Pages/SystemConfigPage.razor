@page "/gateway/system"
@attribute [Authorize]
@attribute [RolePermission]
@inherits ComponentDefault
@using BootstrapBlazor.Components
@using Microsoft.AspNetCore.Authorization
@using ThingsGateway.Admin.Razor
@using ThingsGateway.AutoUpdate
@using ThingsGateway.Gateway.Application
@using ThingsGateway.Admin.Application
@using ThingsGateway.Razor
@namespace ThingsGateway.Gateway.Management


<div class="appconfig">
    <Tab class="h-100">

        <TabItem Text=@RedundancyLocalizer[nameof(Redundancy)]>

            <Card class="mb-2">

                <HeaderTemplate>

                    <RedundancyPage> </RedundancyPage>

                </HeaderTemplate>

                <BodyTemplate>


                    <EditComponent Model="Redundancy" OnSave="OnSaveRedundancy" />


                </BodyTemplate>

            </Card>

        </TabItem>

        <TabItem Text=@ManagementLocalizer["CheckUpdate"]>

            <Card class="mb-2">

                <BodyTemplate>
                    <UpdateZipFilePage></UpdateZipFilePage>
                </BodyTemplate>

            </Card>

        </TabItem>


        <TabItem Text=@ManagementLocalizer["Restart"]>

            <Card class="mb-2">



                <BodyTemplate>

                    <Button OnClick="OnRestart" Text=@ManagementLocalizer["Restart"]></Button>

                </BodyTemplate>

            </Card>

        </TabItem>

    </Tab>

</div>

